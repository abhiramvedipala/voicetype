# Copy this file to .env and fill in your values. .env is gitignored.

# Hotkey that triggers push-to-talk recording (pynput key name)
VOICETYPE_HOTKEY=alt_r

# faster-whisper model size: tiny | base | small | medium
VOICETYPE_WHISPER_MODEL=base

# How transcribed text gets typed out: keystrokes | clipboard
# keystrokes = simulated typing, works everywhere, slower for long text
# clipboard  = paste via Cmd+V, instant, but overwrites your clipboard
VOICETYPE_INJECT_MODE=keystrokes

# AI cleanup mode: send transcript to an LLM to strip filler words (true/false)
VOICETYPE_CLEANUP_ENABLED=false

# Prompt mode: reformat rambling speech into a clear instruction (true/false)
VOICETYPE_PROMPT_MODE=false

# --- Cleanup mode LLM backend ---
# Any OpenAI-compatible endpoint works: set API key, model, and base URL
# together as a matched trio. Leave VOICETYPE_LLM_BASE_URL empty for OpenAI
# itself. See README's "Cleanup mode backends" table for details.

# API key for cleanup mode (leave empty if cleanup is off). Ollama ignores
# the value but the client library still requires a non-empty string —
# use the literal word "ollama".
VOICETYPE_API_KEY=

# Chat model to use for cleanup mode — must match the backend below.
VOICETYPE_LLM_MODEL=gpt-4o-mini

VOICETYPE_LLM_BASE_URL=

# --- Preset examples (uncomment ONE pair of LLM_MODEL/LLM_BASE_URL above) ---
# Gemini   — VOICETYPE_LLM_MODEL=gemini-2.5-flash
#            VOICETYPE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Groq     — VOICETYPE_LLM_MODEL=llama-3.1-8b-instant
#            VOICETYPE_LLM_BASE_URL=https://api.groq.com/openai/v1
# Ollama   — VOICETYPE_LLM_MODEL=qwen2.5:3b
#            VOICETYPE_LLM_BASE_URL=http://localhost:11434/v1
#            VOICETYPE_API_KEY=ollama
#            (free, local, no quota — requires `ollama serve` running; see README)

# Use OpenAI's hosted whisper API instead of local transcription (true/false)
VOICETYPE_USE_API_TRANSCRIPTION=false
