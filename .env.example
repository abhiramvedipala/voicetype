# Copy this file to .env and fill in your values. .env is gitignored.

# Hotkey that triggers push-to-talk recording (pynput key name)
VOICETYPE_HOTKEY=alt_r

# faster-whisper model size: tiny | base | small | medium
VOICETYPE_WHISPER_MODEL=base

# How transcribed text gets typed out: keystrokes | clipboard
# keystrokes = simulated typing, works everywhere, slower for long text
# clipboard  = paste via Cmd+V, instant, but overwrites your clipboard
VOICETYPE_INJECT_MODE=keystrokes

# AI cleanup mode: send transcript to an LLM to strip filler words (true/false)
VOICETYPE_CLEANUP_ENABLED=false

# Prompt mode: reformat rambling speech into a clear instruction (true/false)
VOICETYPE_PROMPT_MODE=false

# API key for cleanup mode (leave empty if cleanup is off)
VOICETYPE_API_KEY=

# Use OpenAI's hosted whisper API instead of local transcription (true/false)
VOICETYPE_USE_API_TRANSCRIPTION=false
